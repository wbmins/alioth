# Reference: <https://postmarketos.org/devicepkg>
# Maintainer: nasaarmas <nasarmas@tlen.pl>
pkgname=device-xiaomi-alioth
pkgdesc="Xiaomi Poco F3"
pkgver=5
pkgrel=2
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	linux-postmarketos-qcom-sm8250-alioth
	alsa-ucm-conf
	bootmac
	hexagonrpcd>=0.3.2-r3
	make-dynpart-mappings
	mesa-vulkan-freedreno
	mkbootimg
	postmarketos-base
	qbootctl
	swclock-offset
	hexagonrpcd-systemd
	firmware-xiaomi-alioth
	firmware-qcom-adreno-a650
	linux-firmware-qcom
	linux-firmware-qca
	linux-firmware-ath11k
	tqftpserv
"

makedepends="devicepkg-dev"
source="
	81-libssc-xiaomi-alioth.rules
    alsa-ucm-conf/alioth.conf
    alsa-ucm-conf/HiFi.conf
	deviceinfo
	hexagonrpcd.confd
	modules-initfs
    wifi-powersave.conf
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
    devicepkg_package $startdir $pkgname

	# device-specific alsa ucm conf
	install -Dm644 "$srcdir/alioth.conf" \
		"$pkgdir/usr/share/alsa/ucm2/Xiaomi/alioth/alioth.conf"

	install -Dm644 "$srcdir/HiFi.conf" \
		"$pkgdir/usr/share/alsa/ucm2/Xiaomi/alioth/HiFi.conf"

	mkdir -p "$pkgdir/usr/share/alsa/ucm2/conf.d/sm8250"
	ln -s ../../Xiaomi/alioth/alioth.conf \
		"$pkgdir/usr/share/alsa/ucm2/conf.d/sm8250/xiaomi-alioth.conf"

    install -Dm644 "$srcdir/81-libssc-xiaomi-alioth.rules" \
        "$pkgdir/etc/udev/rules.d/81-libssc-xiaomi-alioth.rules"
	
    install -Dm644 "$srcdir/hexagonrpcd.confd" \
		"$pkgdir/usr/share/hexagonrpcd/hexagonrpcd-sdsp.conf"

    # makes the device more responsive through ssh
    install -Dm644 "$srcdir/wifi-powersave.conf" \
        "$pkgdir/etc/NetworkManager/conf.d/wifi-powersave.conf"
}


